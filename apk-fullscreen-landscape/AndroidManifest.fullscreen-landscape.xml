<!--
  Copy these activity settings into the APK project's AndroidManifest.xml.
  They are required for:
  1. no browser address bar: run the game inside an app Activity/WebView, not Chrome
  2. forced landscape: ignore the user's auto-rotate setting
-->
<activity
    android:name=".MainActivity"
    android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation"
    android:exported="true"
    android:launchMode="singleTask"
    android:screenOrientation="landscape"
    android:theme="@style/AppTheme.FullscreenLandscape">
    <intent-filter>
        <action android:name="android.intent.action.MAIN" />
        <category android:name="android.intent.category.LAUNCHER" />
    </intent-filter>
</activity>
